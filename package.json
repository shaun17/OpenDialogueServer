{
  "name": "open-dialogue-server",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:init": "wrangler d1 execute opendialogue-db --local --file=src/db/schema.sql",
    "db:migrate": "wrangler d1 execute opendialogue-db --local --file=src/db/migrate_v2.sql",
    "db:init:remote": "wrangler d1 execute opendialogue-db --remote --file=src/db/schema.sql",
    "db:migrate:remote": "wrangler d1 execute opendialogue-db --remote --file=src/db/migrate_v2.sql",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241022.0",
    "@cloudflare/vitest-pool-workers": "^0.5.0",
    "typescript": "^5.5.4",
    "vitest": "^2.0.0",
    "wrangler": "^3.80.0"
  }
}
