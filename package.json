{
  "name": "open-dialogue-server",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:init": "wrangler d1 execute opendialogue-db --file=src/db/schema.sql",
